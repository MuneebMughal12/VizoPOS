# Fetch native-module prebuilds for the Electron runtime (not Node).
# better-sqlite3 only ever runs inside Electron's main process, and this
# machine has no C++ build tools — so the target must match the pinned
# electron version in package.json exactly. Electron 42 = ABI 146, the
# newest ABI better-sqlite3 12.x publishes Windows prebuilds for.
runtime = electron
target = 42.7.0
disturl = https://electronjs.org/headers
